#!/usr/bin/env python3
"""
opencode-tree — Isolated opencode environments via git worktree + tmux.

For git repos: creates a temporary git worktree, launches opencode in tmux,
and auto-cleans the worktree when the session ends.

For plain directories: just launches opencode in tmux with no git operations.
"""

import argparse
import json
import os
import random
import shutil
import signal
import string
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

VERSION = "0.1.0"

XDG_DATA_HOME = Path(os.environ.get("XDG_DATA_HOME", Path.home() / ".local" / "share"))
OPENCODE_TREE_DIR = XDG_DATA_HOME / "opencode-tree"

SESSION_PREFIX = "ot"

S = {
    "is_git_mode": True,
    "repo_path": None,
    "target_dir": None,
    "branch": None,
    "worktree_dir": None,
    "session_name": None,
    "is_temp_branch": False,
    "base_branch": None,
    "metadata_file": None,
    "sentinel_file": None,
    "cleanup_done": False,
    "force": False,
    "no_tmux": False,
    "passive_mode": False,
}


# ── I/O helpers ──────────────────────────────────────────────────────
def die(msg: str, code: int = 1) -> None:
    print(f"\033[31merror:\033[0m {msg}", file=sys.stderr)
    sys.exit(code)


def info(msg: str) -> None:
    print(f"\033[32m*\033[0m {msg}")


def warn(msg: str) -> None:
    print(f"\033[33mwarning:\033[0m {msg}", file=sys.stderr)


def confirm(prompt: str, default: bool = False) -> bool:
    suffix = " [Y/n]" if default else " [y/N]"
    try:
        answer = input(f"{prompt}{suffix} ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return default
    if default:
        return answer != "n"
    return answer == "y"


def choose(prompt: str, options: dict) -> str:
    opts = "/".join(options.keys())
    try:
        answer = input(f"{prompt} [{opts}] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return ""
    for key, action in options.items():
        if answer == key:
            return action
    return ""


# ── Subprocess helper ────────────────────────────────────────────────
def run(cmd, cwd=None, capture=False, check=False, quiet=False, input_data=None):
    kwargs = {"cwd": str(cwd) if cwd else None}
    if capture:
        kwargs["stdout"] = subprocess.PIPE
        kwargs["stderr"] = subprocess.PIPE if not quiet else subprocess.DEVNULL
        kwargs["text"] = True
    elif quiet:
        kwargs["stdout"] = subprocess.DEVNULL
        kwargs["stderr"] = subprocess.DEVNULL
    if input_data is not None:
        kwargs["input"] = input_data
    try:
        result = subprocess.run(cmd, **kwargs)
    except FileNotFoundError:
        die(f"Command not found: {cmd[0]}")
    if check and result.returncode != 0:
        detail = result.stderr.strip() if capture else ""
        msg = f"Command failed: {' '.join(cmd)}"
        if detail:
            msg += f"\n  {detail}"
        die(msg)
    return result


# ── Slug ─────────────────────────────────────────────────────────────
def slugify(name: str) -> str:
    name = name.replace("/", "-")
    name = "".join(c if c.isalnum() or c in "-_" else "-" for c in name)
    while "--" in name:
        name = name.replace("--", "-")
    name = name.strip("-")
    return name[:80]


# ── Tool validation ─────────────────────────────────────────────────
def validate_tools():
    if shutil.which("git"):
        ver = run(["git", "--version"], capture=True).stdout.strip()
        info(f"Using {ver}")
    else:
        info("git not found (plain directory mode only)")

    if not S["no_tmux"]:
        if not shutil.which("tmux"):
            warn("tmux not found. Falling back to --no-tmux mode.")
            S["no_tmux"] = True


# ── Path resolution ─────────────────────────────────────────────────
def is_git_repo(path: Path) -> bool:
    return path.exists() and (
        (path / ".git").exists()
        or run(["git", "rev-parse", "--git-dir"], cwd=path, quiet=True).returncode == 0
    )


def resolve_repo(project: str) -> Path:
    p = Path(project)
    if is_git_repo(p):
        return p.resolve()
    p = Path.cwd() / project
    if is_git_repo(p):
        return p.resolve()
    extra_dirs = os.environ.get("OPENCODE_TREE_DIRS", "")
    for base_str in extra_dirs.split(":"):
        if not base_str.strip():
            continue
        p = Path(base_str.strip()) / project
        if is_git_repo(p):
            return p.resolve()
    return None


def resolve_directory(project: str) -> Path:
    p = Path(project)
    if p.is_dir():
        return p.resolve()
    p = Path.cwd() / project
    if p.is_dir():
        return p.resolve()
    extra_dirs = os.environ.get("OPENCODE_TREE_DIRS", "")
    for base_str in extra_dirs.split(":"):
        if not base_str.strip():
            continue
        p = Path(base_str.strip()) / project
        if p.is_dir():
            return p.resolve()
    return None


# ── Git helpers ──────────────────────────────────────────────────────
def git(*args, cwd=None, capture=False, quiet=False, check=False):
    return run(["git"] + list(args), cwd=cwd, capture=capture, quiet=quiet, check=check)


def branch_exists(branch: str, cwd: Path) -> bool:
    return git("rev-parse", "--verify", branch, cwd=cwd, quiet=True, capture=True).returncode == 0


def remote_branch_exists(branch: str, cwd: Path) -> bool:
    return git("rev-parse", "--verify", f"origin/{branch}", cwd=cwd, quiet=True, capture=True).returncode == 0


def detect_default_branch(repo: Path) -> str:
    result = git("symbolic-ref", "refs/remotes/origin/HEAD", cwd=repo, capture=True, quiet=True)
    if result.returncode == 0:
        return result.stdout.strip().replace("refs/remotes/origin/", "")
    for candidate in ["main", "master"]:
        if branch_exists(candidate, repo) or remote_branch_exists(candidate, repo):
            return candidate
    return "main"


def check_existing_worktree(branch: str, cwd: Path):
    result = git("worktree", "list", "--porcelain", cwd=cwd, capture=True)
    current_wt = None
    current_branch = None
    for line in result.stdout.strip().split("\n"):
        if line.startswith("worktree "):
            current_wt = line[9:]
        elif line.startswith("branch refs/heads/"):
            current_branch = line[17:]
            if current_branch == branch:
                return current_wt
    return None


def is_dirty(cwd: Path):
    status = git("status", "--porcelain", cwd=cwd, capture=True).stdout.strip()
    stash_list = git("stash", "list", cwd=cwd, capture=True).stdout.strip()
    dirty = len([l for l in status.split("\n") if l]) if status else 0
    stash = len([l for l in stash_list.split("\n") if l]) if stash_list else 0
    return dirty, stash


def unpushed_commits(branch: str, base: str, cwd: Path):
    result = git("log", f"origin/{base}..{branch}", "--oneline", cwd=cwd, capture=True, quiet=True)
    lines = result.stdout.strip()
    return [l for l in lines.split("\n") if l] if lines else []


# ── Branch strategy (git mode only) ─────────────────────────────────
def create_branch_strategy(branch_arg: str) -> str:
    repo = S["repo_path"]
    base = S["base_branch"]

    if not branch_arg:
        ts = int(time.time())
        rand = "".join(random.choices(string.digits, k=6))
        br = f"openworktree/{ts}-{rand}"
        S["is_temp_branch"] = True
        info(f"No branch specified — creating temp branch: \033[36m{br}\033[0m")

        base_ref = f"origin/{base}"
        if remote_branch_exists(base, repo):
            git("fetch", "origin", base, cwd=repo, quiet=True)
            git("branch", br, base_ref, cwd=repo, check=True)
        elif branch_exists(base, repo):
            git("branch", br, base, cwd=repo, check=True)
        else:
            die(f"Base branch '{base}' not found locally or on origin")
        return br

    if branch_exists(branch_arg, repo):
        return branch_arg
    if remote_branch_exists(branch_arg, repo):
        info(f"Creating local branch '{branch_arg}' tracking origin/{branch_arg}")
        git("branch", "--track", branch_arg, f"origin/{branch_arg}", cwd=repo, check=True)
        return branch_arg

    info(f"Branch '{branch_arg}' not found — creating from origin/{base}")
    git("fetch", "origin", base, cwd=repo, quiet=True)
    base_ref = f"origin/{base}"
    if not remote_branch_exists(base, repo):
        die(f"Base branch 'origin/{base}' not found")
    git("branch", branch_arg, base_ref, cwd=repo, check=True)
    return branch_arg


# ── Worktree (git mode only) ────────────────────────────────────────
def create_worktree(branch: str):
    repo = S["repo_path"]
    repo_name = repo.name
    slug = slugify(branch)
    wt_dir = OPENCODE_TREE_DIR / repo_name / slug

    S["worktree_dir"] = wt_dir
    S["metadata_file"] = wt_dir / ".opencode-tree.json"
    S["sentinel_file"] = wt_dir / ".opencode-tree.cleaning"

    existing = check_existing_worktree(branch, repo)
    if existing:
        if Path(existing) == wt_dir:
            info(f"Worktree already exists at {existing}")
            return
        die(f"Branch '{branch}' already has a worktree at: {existing}. Use --resume.")

    if wt_dir.exists():
        meta_file = wt_dir / ".opencode-tree.json"
        if meta_file.exists():
            warn("Worktree directory exists but is not registered with git. Removing...")
            shutil.rmtree(wt_dir)
        else:
            die(f"Directory {wt_dir} already exists and is not an opencode-tree worktree")

    wt_dir.parent.mkdir(parents=True, exist_ok=True)
    info(f"Creating worktree at: \033[36m{wt_dir}\033[0m")
    git("worktree", "add", str(wt_dir), branch, cwd=repo, check=True)

    valid = git("rev-parse", "--git-dir", cwd=wt_dir, quiet=True).returncode == 0
    if not valid:
        shutil.rmtree(wt_dir, ignore_errors=True)
        die("Worktree creation failed — directory cleaned up")


def write_metadata():
    meta = {
        "version": 1,
        "mode": "git",
        "project": S["repo_path"].name,
        "branch": S["branch"],
        "repo_path": str(S["repo_path"]),
        "temp_branch": S["is_temp_branch"],
        "base_branch": S["base_branch"],
        "created_at": datetime.now(timezone.utc).isoformat(),
        "tmux_session": S["session_name"],
        "script_pid": os.getpid(),
    }
    S["metadata_file"].write_text(json.dumps(meta, indent=2))


def read_metadata(filepath: Path) -> dict:
    try:
        return json.loads(filepath.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        return None


# ── Tmux (shared) ────────────────────────────────────────────────────
def tmux_has_session(name: str) -> bool:
    if not shutil.which("tmux"):
        return False
    return run(["tmux", "has-session", "-t", name], quiet=True).returncode == 0


def _create_tmux_session(session: str, cwd: Path, label: str):
    run(["tmux", "new-session", "-d", "-s", session, "-c", str(cwd)])
    run(["tmux", "set", "-g", "base-index", "1"], quiet=True)
    run(["tmux", "set", "-g", "pane-base-index", "1"], quiet=True)
    run(["tmux", "set", "-g", "status-left",
         f"#[fg=green][OT: {label}]#[default] "], quiet=True)
    run(["tmux", "rename-window", "-t", f"{session}:1", "code"])
    run(["tmux", "send-keys", "-t", f"{session}:1", "opencode", "Enter"])
    run(["tmux", "new-window", "-t", f"{session}:2", "-c", str(cwd), "-n", "shell"])
    run(["tmux", "send-keys", "-t", f"{session}:2",
         f"echo '# opencode-tree session: {cwd}'", "Enter"])

    info(f"Tmux session \033[36m{session}\033[0m ready")
    info(f"  Window 1: opencode")
    info(f"  Window 2: shell")


def setup_tmux_session():
    repo_name = S["repo_path"].name
    slug = slugify(S["branch"])
    session = f"{SESSION_PREFIX}-{repo_name}-{slug}"
    S["session_name"] = session
    if tmux_has_session(session):
        info(f"Session '{session}' already exists — will reattach")
        return
    info(f"Creating tmux session: \033[36m{session}\033[0m")
    _create_tmux_session(session, S["worktree_dir"], f"{repo_name}/{slug}")
    info(f"  Worktree: {S['worktree_dir']}")


def setup_plain_session():
    dir_name = S["target_dir"].name
    slug = slugify(S["target_dir"].name)
    session = f"{SESSION_PREFIX}-plain-{slug}"
    S["session_name"] = session
    if tmux_has_session(session):
        info(f"Session '{session}' already exists — will reattach")
        return
    info(f"Creating tmux session: \033[36m{session}\033[0m")
    _create_tmux_session(session, S["target_dir"], f"plain/{slug}")
    info(f"  Directory: {S['target_dir']}")


def attach_loop():
    session = S["session_name"]
    info("Detach with Ctrl+B d. Kill session (exit all windows) to trigger cleanup.")

    while True:
        if not tmux_has_session(session):
            time.sleep(1)
            if not tmux_has_session(session):
                break
        run(["tmux", "attach-session", "-t", session], stderr=subprocess.DEVNULL)


# ── Cleanup ──────────────────────────────────────────────────────────
def cleanup():
    if S["cleanup_done"]:
        return
    S["cleanup_done"] = True

    sentinel = S.get("sentinel_file")
    if sentinel and sentinel.exists():
        die("Cleanup already in progress. Second interrupt = hard exit.", code=2)

    if not S["is_git_mode"]:
        info("Session ended.")
        return

    wt_dir = S.get("worktree_dir")
    if not wt_dir or not wt_dir.exists():
        return

    if sentinel:
        sentinel.touch()

    print()
    info("Session ended. Running git cleanup...")

    repo = S.get("repo_path")
    branch = S.get("branch")
    is_temp = S.get("is_temp_branch", False)

    if repo and repo.exists():
        base = S.get("base_branch", detect_default_branch(repo))
        d_files, s_count = is_dirty(wt_dir) if wt_dir.exists() else (0, 0)

        if d_files > 0 or s_count > 0:
            parts = []
            if d_files > 0:
                parts.append(f"{d_files} uncommitted file(s)")
            if s_count > 0:
                parts.append(f"{s_count} stashes")
            warn(f"Worktree has dirty state: {', '.join(parts)}")

            if not S["force"]:
                if is_temp:
                    if not confirm("Temp branch — changes will be lost. Remove?"):
                        die("Cleanup aborted")
                else:
                    action = choose("Uncommitted changes.",
                                    {"s": "stash", "d": "destroy", "c": "cancel"})
                    if action in ("cancel", ""):
                        die("Cleanup aborted")
                    elif action == "stash":
                        ts = int(time.time())
                        git("stash", "push", "-m", f"opencode-tree auto-stash {ts}", cwd=wt_dir)
                        info("Changes stashed")

        if is_temp and branch:
            if remote_branch_exists(branch, repo):
                warn(f"Branch '{branch}' also exists on origin.")
                info(f"  Delete remote: git push origin --delete {branch}")

            if branch_exists(branch, repo):
                unpushed = unpushed_commits(branch, base, repo)
                if unpushed:
                    if S["force"] or confirm(
                            f"Temp branch has {len(unpushed)} unpushed commit(s). Delete?",
                            default=False):
                        git("branch", "-D", branch, cwd=repo)
                    else:
                        info(f"Keeping branch '{branch}'")
                else:
                    git("branch", "-D", branch, cwd=repo)

    if wt_dir.exists() and repo and repo.exists():
        if git("rev-parse", "--git-dir", cwd=wt_dir, quiet=True).returncode == 0:
            if S["force"]:
                git("worktree", "remove", "--force", str(wt_dir), cwd=repo)
            else:
                result = git("worktree", "remove", str(wt_dir), cwd=repo, capture=True)
                if result.returncode != 0:
                    warn(f"Failed to remove worktree. Use --force to override.")
        else:
            shutil.rmtree(wt_dir, ignore_errors=True)

    if repo and repo.exists():
        git("worktree", "prune", cwd=repo)

    for d in [wt_dir.parent, wt_dir.parent.parent]:
        if d.exists():
            try:
                d.rmdir()
            except OSError:
                pass

    info("Cleanup complete.")


# ── Prune stale ──────────────────────────────────────────────────────
def prune_stale():
    if not OPENCODE_TREE_DIR.exists():
        info(f"No data directory at {OPENCODE_TREE_DIR}")
        return

    info(f"Scanning for stale worktrees in {OPENCODE_TREE_DIR}...")
    found = False

    for metafile in OPENCODE_TREE_DIR.rglob(".opencode-tree.json"):
        meta = read_metadata(metafile)
        if not meta:
            continue

        wt_dir = metafile.parent
        session_name = meta.get("tmux_session", "")
        mode = meta.get("mode", "git")

        if session_name and tmux_has_session(session_name):
            continue

        found = True
        info(f"Removing stale: \033[36m{wt_dir}\033[0m")

        if mode == "git":
            repo_path_str = meta.get("repo_path", "")
            repo_path = Path(repo_path_str) if repo_path_str else None
            if repo_path and repo_path.exists():
                git("worktree", "remove", "--force", str(wt_dir), cwd=repo_path,
                    capture=True, quiet=True)
                git("worktree", "prune", cwd=repo_path)

        shutil.rmtree(wt_dir, ignore_errors=True)
        for d in [wt_dir.parent, wt_dir.parent.parent]:
            if d.exists():
                try:
                    d.rmdir()
                except OSError:
                    pass

    if not found:
        info("No stale worktrees found.")


# ── List sessions ────────────────────────────────────────────────────
def collect_sessions():
    sessions = []
    active_tmux = set()

    if shutil.which("tmux"):
        result = run(["tmux", "list-sessions", "-F", "#{session_name}"],
                     capture=True, quiet=True)
        if result.returncode == 0:
            for name in result.stdout.strip().split("\n"):
                name = name.strip()
                if name.startswith(f"{SESSION_PREFIX}-"):
                    active_tmux.add(name)

    if OPENCODE_TREE_DIR.exists():
        for metafile in sorted(OPENCODE_TREE_DIR.rglob(".opencode-tree.json")):
            meta = read_metadata(metafile)
            if not meta:
                continue
            sn = meta.get("tmux_session", "")
            sessions.append({
                "session": sn,
                "project": meta.get("project", "?"),
                "branch": meta.get("branch", "?"),
                "mode": meta.get("mode", "?"),
                "active": sn in active_tmux,
                "temp_branch": meta.get("temp_branch", False),
                "created_at": meta.get("created_at", ""),
                "repo_path": meta.get("repo_path", ""),
            })
            active_tmux.discard(sn)

    for name in sorted(active_tmux):
        sessions.append({
            "session": name,
            "project": "?",
            "branch": "?",
            "mode": "?",
            "active": True,
            "temp_branch": False,
            "created_at": "",
            "repo_path": "",
        })

    return sessions


def display_sessions(sessions):
    active = [s for s in sessions if s["active"]]
    stale = [s for s in sessions if not s["active"]]
    cols, _ = shutil.get_terminal_size()

    if active:
        print(f"\033[1mActive sessions ({len(active)}):\033[0m")
        print("")
        for s in sorted(active, key=lambda x: x["session"]):
            label = f"{s['project']}/{s['branch']}" if s["mode"] == "git" else f"{s['project']} (plain)"
            mode_str = "worktree" if s["mode"] == "git" else "plain"
            print(f"  \033[32m●\033[0m  {s['session']}")
            print(f"     target:  {label}")
            print(f"     mode:    {mode_str}")
            if s["temp_branch"]:
                print(f"     note:    temp branch")
            print("")

    if stale:
        print(f"\033[90mStale ({len(stale)}):\033[0m")
        print("")
        for s in sorted(stale, key=lambda x: x["session"]):
            label = f"{s['project']}/{s['branch']}" if s["mode"] == "git" else f"{s['project']}"
            print(f"  \033[90m○\033[0m  {s['session']}")
            print(f"     target:  {label}")
            print("")

    if not active and not stale:
        print("No sessions found.")
        print("Start one with: opencode-tree .")


def display_sessions_compact(sessions):
    active = [s for s in sessions if s["active"]]
    stale = [s for s in sessions if not s["active"]]

    ts = datetime.now().strftime("%H:%M:%S")
    print(f"\033[1mopencode-tree sessions\033[0m  [{ts}]  —  Ctrl+C to exit")
    print("")

    for s in sorted(active, key=lambda x: x["session"]):
        label = f"{s['project']}/{s['branch']}" if s["mode"] == "git" else f"{s['project']} (plain)"
        mode_str = "W" if s["mode"] == "git" else "P"
        temp_mark = "T" if s["temp_branch"] else " "
        print(f"  \033[32m●\033[0m  {mode_str}{temp_mark}  {s['session']:<45} {label}")

    for s in sorted(stale, key=lambda x: x["session"]):
        label = f"{s['project']}/{s['branch']}" if s["mode"] == "git" else f"{s['project']}"
        print(f"  \033[90m○\033[0m  ?  {s['session']:<45} {label}   \033[90mstale\033[0m")

    if not active and not stale:
        print("  No sessions.")


def run_list_mode(watch: bool):
    S["passive_mode"] = True

    if not watch:
        sessions = collect_sessions()
        display_sessions(sessions)
        return

    try:
        while True:
            os.system("clear")
            sessions = collect_sessions()
            display_sessions_compact(sessions)
            time.sleep(2)
    except KeyboardInterrupt:
        print()
        pass


# ── Resume ───────────────────────────────────────────────────────────
def resume_git_session(project: str, branch_arg: str):
    if branch_arg:
        slug = slugify(branch_arg)
        session = f"{SESSION_PREFIX}-{S['repo_path'].name}-{slug}"
        if not tmux_has_session(session):
            die(f"Session '{session}' not found.")
        wt_dir = OPENCODE_TREE_DIR / S["repo_path"].name / slug
        S.update(session_name=session, worktree_dir=wt_dir,
                 metadata_file=wt_dir / ".opencode-tree.json",
                 sentinel_file=wt_dir / ".opencode-tree.cleaning")
        info(f"Resuming: \033[36m{session}\033[0m")
        attach_loop()
        return

    existing = []
    for d in OPENCODE_TREE_DIR.iterdir():
        if d.is_dir() and d.name == S["repo_path"].name:
            for wt in d.iterdir():
                meta = read_metadata(wt / ".opencode-tree.json")
                if meta and meta.get("tmux_session", "") and tmux_has_session(meta["tmux_session"]):
                    existing.append(meta["tmux_session"])

    if not existing:
        die(f"No sessions found for '{project}'")
    elif len(existing) == 1:
        S["session_name"] = existing[0]
        info(f"Resuming: \033[36m{existing[0]}\033[0m")
        attach_loop()
    else:
        print("Multiple sessions:")
        for s in existing:
            print(f"  {s}")
        die("Specify a branch.")


def resume_plain_session(project: str):
    dir_path = Path(project).resolve() if Path(project).exists() else None
    if not dir_path:
        die(f"Directory not found: {project}")

    slug = slugify(dir_path.name)
    session = f"{SESSION_PREFIX}-plain-{slug}"

    if not tmux_has_session(session):
        die(f"No session found for '{project}'. Start one without --resume.")

    S["session_name"] = session
    S["target_dir"] = dir_path
    info(f"Resuming plain session: \033[36m{session}\033[0m")
    attach_loop()


# ── Signal ───────────────────────────────────────────────────────────
def handle_signal(signum, frame):
    print()
    if S.get("passive_mode"):
        sys.exit(0)
    warn("Interrupt received. Running cleanup...")
    cleanup()
    sys.exit(1)


# ── Argument parsing ────────────────────────────────────────────────
def parse_args(argv):
    parser = argparse.ArgumentParser(
        prog="opencode-tree",
        description="Isolated opencode environments via git worktree + tmux",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""\
Examples:
  opencode-tree .                         Temp branch from current git repo
  opencode-tree /path/to/repo             Temp branch, specific repo
  opencode-tree .  feature/x              Use existing branch
  opencode-tree /some/dir                 Plain mode (non-git directory)
  opencode-tree --resume .                Reattach to session
  opencode-tree --list                    Show all sessions
  opencode-tree --list --watch            Live-updating session monitor
  opencode-tree --prune                   Clean stale worktrees

Non-git directories:
  If the given path is not a git repo, opencode-tree skips all git operations
  and just launches opencode in tmux for that directory.

Environment:
  OPENCODE_TREE_DIRS  Colon-separated directories to search by name
""")
    parser.add_argument("project", nargs="?",
                        help="Path or name (git repo or plain directory)")
    parser.add_argument("branch", nargs="?",
                        help="Branch name (git mode only; auto-generated if omitted)")
    parser.add_argument("-f", "--force", action="store_true",
                        help="Skip all prompts during cleanup")
    parser.add_argument("--no-tmux", action="store_true",
                        help="Run opencode in current terminal (no tmux)")
    parser.add_argument("-r", "--resume", action="store_true",
                        help="Reattach to an existing session")
    parser.add_argument("--list", action="store_true",
                        help="Show all sessions (active and stale)")
    parser.add_argument("-w", "--watch", action="store_true",
                        help="With --list, continuously refresh the view")
    parser.add_argument("--prune", action="store_true",
                        help="Remove stale worktrees and exit")
    parser.add_argument("-b", "--base", default=None,
                        help="Base branch (git mode; auto-detected by default)")
    parser.add_argument("--version", action="version", version=f"opencode-tree v{VERSION}")

    args = parser.parse_args(argv)

    if args.prune:
        return args

    if args.watch and not args.list:
        args.list = True

    if args.list:
        return args

    if not args.project and not args.resume:
        cwd = Path.cwd()
        if is_git_repo(cwd) or cwd.is_dir():
            args.project = "."
        else:
            parser.print_help()
            print()
            die("Project name or path required (or use --prune)")

    return args


# ── Main ─────────────────────────────────────────────────────────────
def main():
    signal.signal(signal.SIGINT, handle_signal)
    signal.signal(signal.SIGTERM, handle_signal)

    args = parse_args(sys.argv[1:])
    S["force"] = args.force
    S["no_tmux"] = args.no_tmux

    if args.list or args.watch:
        run_list_mode(args.watch)
        return

    if args.prune:
        S["passive_mode"] = True
        prune_stale()
        return

    validate_tools()
    info(f"opencode-tree v{VERSION}")

    if args.project:
        info(f"Resolving: \033[36m{args.project}\033[0m")

        repo_path = resolve_repo(args.project)
        if repo_path:
            S["is_git_mode"] = True
            S["repo_path"] = repo_path
            info(f"Git repo: \033[36m{repo_path}\033[0m")
        else:
            plain_path = resolve_directory(args.project)
            if not plain_path:
                die(f"Not found: '{args.project}'. Provide an existing path or set OPENCODE_TREE_DIRS.")
            S["is_git_mode"] = False
            S["target_dir"] = plain_path
            info(f"Directory: \033[36m{plain_path}\033[0m (non-git mode)")

    if args.resume:
        if S["is_git_mode"]:
            resume_git_session(args.project, args.branch)
        else:
            resume_plain_session(args.project)
        return

    if not S["is_git_mode"]:
        if S["no_tmux"]:
            info("Starting opencode (no tmux)...")
            os.chdir(str(S["target_dir"]))
            run(["opencode"])
            return
        setup_plain_session()
        attach_loop()
        cleanup()
        return

    S["base_branch"] = args.base or detect_default_branch(S["repo_path"])
    info(f"Base branch: \033[36m{S['base_branch']}\033[0m")

    branch = create_branch_strategy(args.branch)
    S["branch"] = branch

    create_worktree(branch)

    slug = slugify(branch)
    S["session_name"] = f"{SESSION_PREFIX}-{S['repo_path'].name}-{slug}"
    write_metadata()

    if S["no_tmux"]:
        info("Starting opencode in worktree (no tmux)...")
        info(f"Worktree: \033[36m{S['worktree_dir']}\033[0m")
        os.chdir(str(S["worktree_dir"]))
        run(["opencode"])
        cleanup()
        return

    setup_tmux_session()
    attach_loop()
    cleanup()


if __name__ == "__main__":
    main()
